# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fastfeast

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=fastfeast-dev-jwt-secret-key-2026
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
